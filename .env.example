# =============================================================================
# Barna Gestoría — Variables de entorno
# Copia a .env.local:  cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL — Neon recomendado)
# -----------------------------------------------------------------------------
# Neon Dashboard → tu proyecto → Connection Details:
#
# DATABASE_URL  = connection string "Pooled" (termina en -pooler...)
# DIRECT_URL    = connection string "Direct" (sin pooler, para migraciones)
#
# Ejemplo Neon:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"
#
# Supabase (alternativa):
# DATABASE_URL = URI "Transaction" pooler (puerto 6543)
# DIRECT_URL   = URI "Session" direct (puerto 5432)
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# -----------------------------------------------------------------------------
# OCR de facturas (DeepSeek)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_INVOICE_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# NextAuth — OAuth social (Google / Outlook)
# -----------------------------------------------------------------------------
# Genera secreto: openssl rand -base64 32
#
# VERCEL (Settings → Environment Variables):
#   NEXTAUTH_SECRET        = (openssl rand -base64 32)
#   NEXTAUTH_URL           = https://tu-dominio.vercel.app
#   GOOGLE_CLIENT_ID       = desde Google Cloud Console
#   GOOGLE_CLIENT_SECRET   = desde Google Cloud Console
#   AZURE_AD_CLIENT_ID     = desde Azure Portal (App registration)
#   AZURE_AD_CLIENT_SECRET = desde Azure Portal
#   AZURE_AD_TENANT_ID     = common  (opcional; por defecto "common")
#
# Redirect URIs en los proveedores OAuth:
#   Google:  https://tu-dominio.vercel.app/api/oauth/callback/google
#   Outlook: https://tu-dominio.vercel.app/api/oauth/callback/azure-ad
#   (también válido en Azure: .../api/auth/callback/azure-ad — rewrite en next.config)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
