# =============================================================================
# Barna Gestoría — Variables de entorno
# Copia a .env.local:  cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL — Neon recomendado)
# -----------------------------------------------------------------------------
# Neon Dashboard → tu proyecto → Connection Details:
#
# DATABASE_URL  = connection string "Pooled" (termina en -pooler...)
# DIRECT_URL    = connection string "Direct" (sin pooler, para migraciones)
#
# Ejemplo Neon:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"
#
# Supabase (alternativa):
# DATABASE_URL = URI "Transaction" pooler (puerto 6543)
# DIRECT_URL   = URI "Session" direct (puerto 5432)
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# -----------------------------------------------------------------------------
# OCR de facturas (DeepSeek) — SOLO SERVIDOR, nunca NEXT_PUBLIC_
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_INVOICE_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# URL pública de la app (única variable NEXT_PUBLIC_ obligatoria)
# -----------------------------------------------------------------------------
# Local:
#   NEXT_PUBLIC_APP_URL=http://localhost:3000
#   NEXTAUTH_URL=http://localhost:3000
#
# Producción (dominio definitivo o Vercel temporal):
#   NEXT_PUBLIC_APP_URL=https://v0-factura-y-extractos-web.vercel.app
#   NEXTAUTH_URL=https://v0-factura-y-extractos-web.vercel.app
#
# Tras cambiar la URL en producción, ejecuta: npm run native:config
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# NextAuth — OAuth social (Google / Outlook) — SOLO SERVIDOR
# -----------------------------------------------------------------------------
# Genera secreto: openssl rand -base64 32
#
# VERCEL (Settings → Environment Variables → Production):
#   NEXTAUTH_SECRET        = (openssl rand -base64 32)
#   NEXTAUTH_URL           = https://tu-dominio-definitivo.com
#   NEXT_PUBLIC_APP_URL    = https://tu-dominio-definitivo.com
#   GOOGLE_CLIENT_ID       = Google Cloud Console
#   GOOGLE_CLIENT_SECRET   = Google Cloud Console
#   AZURE_AD_CLIENT_ID     = Azure Portal → App registration (Application ID)
#   AZURE_AD_CLIENT_SECRET = Azure Portal → Certificates & secrets
#   AZURE_AD_TENANT_ID     = common  (multi-tenant) o GUID de tu tenant
#
# Redirect URIs en Google Cloud / Microsoft Entra (sustituir ORIGIN):
#   Google:  {ORIGIN}/api/oauth/callback/google
#            {ORIGIN}/api/auth/callback/google   (legacy, rewrite automático)
#   Outlook: {ORIGIN}/api/oauth/callback/azure-ad
#            {ORIGIN}/api/auth/callback/azure-ad (legacy)
#
# Páginas legales para verificación OAuth:
#   {ORIGIN}/politica-privacidad
#   {ORIGIN}/terminos-servicio
#
# Consulta URIs exactas en producción: GET /api/auth/oauth-status
# Guía completa: docs/OAUTH_PRODUCTION.md
# -----------------------------------------------------------------------------

NEXTAUTH_SECRET=your-nextauth-secret-here

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
