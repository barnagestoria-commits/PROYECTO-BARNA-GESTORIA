# =============================================================================
# CONFIGURACIÓN OCR DE FACTURAS (DeepSeek)
# =============================================================================
#
# 1. Copia este archivo como .env.local en la raíz del proyecto:
#      cp .env.example .env.local
#
# 2. Obtén tu API Key en: https://platform.deepseek.com/api_keys
#
# 3. Pega la clave en DEEPSEEK_API_KEY (sin comillas):
#      DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
#
# 4. Reinicia el servidor de desarrollo:
#      npm run dev
#
# 5. Sube una factura PDF en /dashboard → Facturas Recibidas
#
# NOTAS:
# - .env.local NO se sube a Git (está en .gitignore).
# - DeepSeek procesa el texto extraído del PDF (no admite imágenes ni PDFs escaneados).
# - También se aceptan OPENAI_API_KEY / OPENAI_INVOICE_MODEL como alias legacy.
#
# =============================================================================

# Clave de API de DeepSeek (obligatoria)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Modelo para extraer datos de facturas (opcional, por defecto: deepseek-chat)
DEEPSEEK_INVOICE_MODEL=deepseek-chat

# Base de datos (SQLite en desarrollo)
DATABASE_URL="file:./prisma/dev.db"

# =============================================================================
# NextAuth — OAuth social (Google / Outlook)
# =============================================================================
# Genera un secreto: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft / Outlook OAuth — https://portal.azure.com → App registrations
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
