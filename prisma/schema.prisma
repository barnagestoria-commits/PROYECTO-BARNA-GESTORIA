generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountType {
  GESTORIA
  CLIENTE_FINAL
  EMPRESA
}

enum UserRole {
  ADMIN_GESTOR
  GESTOR
  CLIENTE
}

enum DocumentType {
  FACTURA_RECIBIDA
  FACTURA_EMITIDA
  EXTRACTO_BANCARIO
}

enum DocumentStatus {
  PENDIENTE
  PROCESADO
}

enum FiscalModelCode {
  M111
  M115
  M180
  M303
}

enum AmortizationPeriodization {
  MENSUAL
  TRIMESTRAL
  ANUAL
}

enum DataImportStatus {
  PENDIENTE
  PROCESADO
  ERROR
}

enum ThirdPartyType {
  PROVEEDOR
  CLIENTE
}

enum FiscalDeclarationStatus {
  SIN_DATOS
  PENDIENTE
  PRESENTADO
}

enum CompanyClientProfile {
  PERSONA_FISICA
  AUTONOMO
  PYME
  GRAN_EMPRESA
}

/// Cuenta raíz: despacho de gestoría o cliente final (autónomo/empresa)
model Account {
  id          String      @id @default(cuid())
  name        String
  accountType AccountType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       User[]
  companies   Company[]
}

model User {
  id            String              @id @default(cuid())
  email         String              @unique
  passwordHash  String
  name          String
  phone         String?
  role          UserRole
  accountId     String
  account       Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  sessions      Session[]
  companyAccess UserCompanyAccess[]
}

/// Empresa/cliente fiscal. OCR y extractos siempre vinculados a companyId.
model Company {
  id         String              @id @default(cuid())
  name       String
  cif        String?
  accountId  String
  account    Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  documents        FiscalDocument[]
  userAccess       UserCompanyAccess[]
  accountingEntries AccountingEntry[]
  fiscalDeclarations FiscalDeclaration[]
  fixedAssets          FixedAsset[]
  costCenters          CostCenter[]
  amortizationSettings AmortizationSettings?
  amortizationRuns     AmortizationRun[]
  accountingImports    AccountingDataImport[]
  thirdParties         ThirdParty[]
  ledgerSubaccounts    LedgerSubaccount[]
  fiscalSettings       CompanyFiscalSettings?
}

/// Asignación gestor ↔ empresa cliente (solo cuentas GESTORIA)
model UserCompanyAccess {
  id        String  @id @default(cuid())
  userId    String
  companyId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model FiscalDocument {
  id           String         @id @default(cuid())
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  type         DocumentType
  status       DocumentStatus @default(PENDIENTE)
  sizeBytes    Int
  ocrDataJson       String?
  uploadedById      String?
  uploadedAt        DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  accountingEntryId String?        @unique
  accountingEntry   AccountingEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: SetNull)
}

model Session {
  id              String   @id @default(cuid())
  token           String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeCompanyId String?
  expiresAt       DateTime
  createdAt       DateTime @default(now())
}

/// Asiento contable vinculado a una empresa
model AccountingEntry {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fecha       DateTime    @db.Date
  issueDate   DateTime?   @db.Date
  operationDate DateTime? @db.Date
  invoiceNumber String?
  invoiceDataJson String?
  commandCode String?
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lines       EntryLine[]
  fiscalDocument FiscalDocument?

  @@index([companyId, fecha])
}

/// Línea de un asiento contable (Debe / Haber)
model EntryLine {
  id        String          @id @default(cuid())
  entryId   String
  entry     AccountingEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  sortOrder Int
  cuenta    String
  concepto  String          @default("")
  debe      Decimal         @default(0) @db.Decimal(14, 2)
  haber     Decimal         @default(0) @db.Decimal(14, 2)

  @@index([entryId, sortOrder])
}

/// Estado de presentación de un modelo fiscal por empresa, año y trimestre
model FiscalDeclaration {
  id          String                  @id @default(cuid())
  companyId   String
  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year        Int
  quarter     Int
  modelCode   FiscalModelCode
  status      FiscalDeclarationStatus @default(PENDIENTE)
  submittedAt DateTime?
  notes       String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([companyId, year, quarter, modelCode])
  @@index([companyId, year])
}

/// Perfil fiscal y modelos habilitados por empresa
model CompanyFiscalSettings {
  id               String               @id @default(cuid())
  companyId        String               @unique
  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientProfile    CompanyClientProfile @default(PYME)
  model111Enabled  Boolean              @default(true)
  model115Enabled  Boolean              @default(false)
  model180Enabled  Boolean              @default(false)
  model303Enabled  Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

/// Ficha de inmovilizado (cuentas 21x / 281x / 681x)
model FixedAsset {
  id                   String                      @id @default(cuid())
  companyId            String
  company              Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code                 String
  name                 String
  description          String?
  cuentaInmovilizado   String
  cuentaAmortAcumulada String
  cuentaGastoAmort     String
  acquisitionDate      DateTime                    @db.Date
  acquisitionCost      Decimal                     @db.Decimal(14, 2)
  residualValue        Decimal                     @default(0) @db.Decimal(14, 2)
  usefulLifeMonths     Int
  accumulatedAmort     Decimal                     @default(0) @db.Decimal(14, 2)
  isActive             Boolean                     @default(true)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  costDistributions    FixedAssetCostDistribution[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
}

/// Centro de coste para distribución analítica
model CostCenter {
  id                String                      @id @default(cuid())
  companyId         String
  company           Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code              String
  name              String
  isActive          Boolean                     @default(true)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  assetDistributions FixedAssetCostDistribution[]

  @@unique([companyId, code])
}

/// Distribución analítica de un activo entre centros de coste
model FixedAssetCostDistribution {
  id           String     @id @default(cuid())
  fixedAssetId String
  fixedAsset   FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  costCenterId String
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  percentage   Decimal    @db.Decimal(5, 2)

  @@unique([fixedAssetId, costCenterId])
}

/// Parametrización de amortizaciones por empresa
model AmortizationSettings {
  id            String                    @id @default(cuid())
  companyId     String                    @unique
  company       Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periodization AmortizationPeriodization @default(TRIMESTRAL)
  updatedAt     DateTime                  @updatedAt
  createdAt     DateTime                  @default(now())
}

/// Registro de ejecución de amortizaciones del periodo
model AmortizationRun {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periodLabel String
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  totalAmount Decimal  @db.Decimal(14, 2)
  entryId     String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([companyId, periodStart])
}

/// Importación de datos contables externos (CSV/Excel)
model AccountingDataImport {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fileName     String
  format       String
  status       DataImportStatus @default(PENDIENTE)
  rowsImported Int              @default(0)
  errorMessage String?
  uploadedById String?
  createdAt    DateTime         @default(now())

  @@index([companyId, createdAt])
}

/// Ficha de proveedor (400) o cliente (430) vinculada a subcuenta contable
model ThirdParty {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        ThirdPartyType
  cif         String
  name        String
  accountCode String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([companyId, type, cif])
  @@unique([companyId, accountCode])
  @@index([companyId, type])
}

/// Subcuenta personalizada del plan contable (678.0001, 629.0003, etc.)
model LedgerSubaccount {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentCode  String
  accountCode String
  name        String
  notes       String?
  address     String?
  phone       String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, accountCode])
  @@index([companyId, parentCode])
}
